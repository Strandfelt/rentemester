# Rentemester — eksempel på miljøvariabler.
# Kopiér til `.env` og udfyld. Alle variabler er valgfri: Rentemester kører
# fuldt ud offline uden dem. .env må ALDRIG committes (credentials).

# --- CVR-registret -----------------------------------------------------------
# Opslag i det danske CVR-register (stamdata for egen virksomhed via
# `company sync-cvr`, og auto-udfyldte kunder/leverandører via `--from-cvr`).
# Adgang oprettes gratis på https://datafordeler.dk / https://distribution.virk.dk
# — Rentemester leverer bevidst ingen delte credentials.
CVR_USERNAME=
CVR_PASSWORD=
# Valgfri: override af CVR Elasticsearch-endpointet (kun til test/proxy).
# RENTEMESTER_CVR_ENDPOINT=http://distribution.virk.dk/cvr-permanent

# --- Cockpit (rentemester serve) ---------------------------------------------
# RENTEMESTER_WORKSPACE=/sti/til/workspace
# RENTEMESTER_APP_HOST=127.0.0.1
# RENTEMESTER_APP_PORT=4319

# --- VIES (EU-momsvalidering) ------------------------------------------------
# RENTEMESTER_VIES_ENDPOINT=https://ec.europa.eu/taxation_customs/vies/rest-api/check-vat-number

# --- IMAP bilagsindbakke -----------------------------------------------------
# RENTEMESTER_IMAP_HOST=
# RENTEMESTER_IMAP_PORT=993
# RENTEMESTER_IMAP_USERNAME=
# RENTEMESTER_IMAP_PASSWORD=
# RENTEMESTER_IMAP_MAILBOX=INBOX
