---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SeoEvidence from "../components/SeoEvidence.astro";
import { SITE } from "../consts";

const groups = [
  {
    title: "Input",
    intro: "Sådan kommer data ind i systemet.",
    items: [
      { t: "Bilagsmail", d: "Roadmap: første slice bliver deterministisk intake fra maildrop/EML uden provider-lock-in; usikre cases skal lande i exception-køen." },
      { t: "Dokument-ingest", d: "Importér bilag fra CLI med metadata. Understøtter PDF, billeder, tekst." },
      { t: "Kontakter og virksomheder", d: "Kunde- og leverandørstamdata findes i kernen. Roadmap: bredere kobling til køb, bilag og historik." },
      { t: "Bankimport", d: "CSV-import med automatisk format-detektion for danske banker. DKK og EUR med dagskurs." },
      { t: "MobilePay", d: "Importér transaktioner som CSV. Matches mod fakturaer og bilag." },
    ],
  },
  {
    title: "Bogføring",
    intro: "Hvad systemet kan postere.",
    items: [
      { t: "Manuelle journalposter", d: "Klassiske posteringer med fuld kontrol over konti og moms." },
      { t: "Bankafstemning", d: "Match banklinjer mod bilag og fakturaer." },
      { t: "Modposter", d: "Reverser fejlbogføringer — uden at slette historikken." },
      { t: "Periodestyring", d: "Luk perioder og blokér posteringer i lukkede eller fremtidige perioder." },
      { t: "Valutakøb", d: "Bogfør køb i fx USD/EUR korrekt, også når banken trækker et DKK-beløb på kontoen." },
      { t: "Valuta", d: "EUR-bilag bogføres med dagskurs og valutakursdifferencer." },
      { t: "Anlægsaktiver", d: "Aktivregister, afskrivning og straksafskrivning kan spores fra bilag til periodisk postering, men den skattemæssige vurdering er stadig eksplicit brugeransvar." },
    ],
  },
  {
    title: "Fakturering",
    intro: "Hele fakturalivscyklussen — sporbart i ledgeren.",
    items: [
      { t: "Udstedelse", d: "Validér og udsted fakturaer i dansk format med moms og forfald." },
      { t: "Offentlig e-fakturering", d: "EAN/GLN preview-eksport og deterministisk OIOUBL-handoff er live. Roadmap: direkte PEPPOL-transport til offentlige kunder med de nødvendige kontroller." },
      { t: "Abonnementer", d: "Roadmap: gentagne fakturaer for faste aftaler, perioder, fornyelser og korrekt bogføring." },
      { t: "Bogføring", d: "Postér fakturaer automatisk når de udstedes." },
      { t: "Påmindelser", d: "Registrér rykkere og bogfør dem som debitorhåndtering." },
      { t: "Kompensationsbeløb", d: "Beregn og bogfør lovbestemt kompensation ved dokumenteret forsinkelse." },
      { t: "Renter", d: "Beregn og bogfør morarentekrav ud fra eksplicit referenceinput." },
      { t: "Kreditnota", d: "Udsted kreditnota og refundér mod bank." },
      { t: "Tab på debitorer", d: "Afskriv ubetalte fakturaer korrekt i forhold til moms." },
    ],
  },
  {
    title: "Moms",
    intro: "Dansk moms — den komplekse del.",
    items: [
      { t: "Momsrapport", d: "Generér afstemningsgrundlag for en momsperiode ud fra ledgeren." },
      { t: "Repræsentation", d: "Testet flow for begrænset momsfradrag på repræsentation." },
      { t: "EU-handel", d: "Testet reverse-charge flow for EU-servicekøb." },
      { t: "Import udenfor EU", d: "Roadmap: importmoms og told håndteres separat." },
      { t: "VIES-validering", d: "Validér EU-momsnumre mod VIES før EU-bogføring." },
      { t: "Blandet anvendelse", d: "Roadmap: tydelig fordeling af moms på erhverv vs. privat brug." },
    ],
  },
  {
    title: "Audit & integritet",
    intro: "Det der gør at en revisor kan stole på systemet.",
    items: [
      { t: "Append-only ledger", d: "Posteringer skrives én gang og overskrives aldrig. Rettelser sker som modposter." },
      { t: "Hash-kæde", d: "Hver postering kædes til den forrige med SHA — manipulation kan opdages." },
      { t: "Ed25519-signering", d: "Opt-in kryptografisk signering. Tredjepart kan verificere uden adgang til private nøgler." },
      { t: "Audit verify", d: "CLI-kommando der verificerer hele kæden og signaturen." },
      { t: "Backup-signering", d: "Backups signeres så genoprettelse kan bevises ægte." },
      { t: "SAF-T", d: "Første deterministiske SAF-T-slice er live for ledger og salgsfakturaer. Roadmap: bredere dækning og eventuelle officielle profil-/indsendelseskrav." },
      { t: "Myndighedseksport", d: "Eksportpakke med periodens historik, bilag og verifikationsdata." },
    ],
  },
  {
    title: "Output & rapporter",
    intro: "Det du faktisk får ud.",
    items: [
      { t: "Dashboard", d: "Deterministisk HTML-rapport — samme data giver bit-for-bit samme output." },
      { t: "Portfolio/cockpit", d: "Flere virksomheder kan samles i et lokalt kontrolpanel med portfolio-overblik, uden at det bliver hosted multi-tenant SaaS." },
      { t: "Healthcheck", d: "CLI-status der viser om alt er konsistent." },
      { t: "Statusrapporter", d: "Faktura-status, åbne exceptions, backupstatus og auditstatus." },
      { t: "Myndigheds-/audit-eksport", d: "Eksportpakke til myndigheder med komplet historik, bilag og verifikationsdata." },
      { t: "Revisoradgang", d: "Lokal eksportpakke findes i dag. Roadmap: giv revisor eller andre hosted læse-/skriveadgang med tydelige roller og audit-attribution." },
    ],
  },
  {
    title: "Integration",
    intro: "Sådan taler andre systemer med Rentemester.",
    items: [
      { t: "CLI", d: "Alt er tilgængeligt via kommandolinje. Scriptbart, automatiserbart." },
      { t: "MCP-server", d: "MCP-kompatible klienter kobler op via en struktureret tool-protokol." },
      { t: "Plugin-system", d: "Roadmap: stabilt plugin-lag til PayPal, Zettle, Shopify og andre API’er uden at gøre kernen skrøbelig." },
      { t: "JSON-input", d: "Strukturerede operations-payloads — ingen fri tekst hvor det betyder noget." },
      { t: "Standard CSV", d: "Bank, MobilePay, kontoplan — alt der ikke er proprietært." },
    ],
  },
];
---

<BaseLayout
  title="Funktioner til dansk open source bogføring"
  description="Funktioner og roadmap i Rentemester: bankimport, faktura, momsrapportering, verifiérbar ledger, MCP, audit-eksport og kommende bilagsmail."
  pageType="WebPage"
  datePublished="2026-05-18"
  dateModified="2026-05-21"
  ogImage="/og-funktioner.png"
>
  <PageHero
    eyebrow="Funktioner"
    title="Hvad systemet kan - og hvad der er roadmap"
    lead="En oversigt over funktionerne i Rentemester, grupperet efter hvor de hører hjemme i workflow'et. Roadmap-punkter er markeret direkte i teksten."
  />

  <div class="max-w-container mx-auto px-margin-mobile md:px-margin-desktop py-12 md:py-20 space-y-16">
    {groups.map((g) => (
      <section>
        <div class="mb-8 max-w-2xl">
          <h2 class="font-serif text-3xl md:text-4xl text-primary mb-2">{g.title}</h2>
          <p class="text-on-surface-variant">{g.intro}</p>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-gutter">
          {g.items.map((item) => (
            <article class="bg-surface-container border border-outline-variant/10 p-6 hover:border-primary/30 transition-colors">
              <h3 class="font-serif text-xl text-on-background mb-2">{item.t}</h3>
              <p class="text-on-surface-variant text-[15px] leading-relaxed">{item.d}</p>
            </article>
          ))}
        </div>
      </section>
    ))}
    <SeoEvidence
      sources={[
        { href: `${SITE.github}/blob/main/package.json`, label: "Smoke-flow", external: true },
        { href: `${SITE.github}/tree/main/tests/unit`, label: "Unit tests", external: true },
        { href: `${SITE.github}/tree/main/rules/dk`, label: "Regelbundter", external: true },
      ]}
      related={[
        { href: "/regnskabsprogram", label: "Regnskabsprogram" },
        { href: "/bogfoeringsprogram", label: "Bogføringsprogram" },
        { href: "/saadan-virker-det", label: "Arkitektur" },
      ]}
    />
  </div>
</BaseLayout>
