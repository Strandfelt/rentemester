---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SeoEvidence from "../components/SeoEvidence.astro";
import { SITE } from "../consts";

const page = {
  pathname: "/bogfoering-for-freelancere",
  title: "Bogføring for freelancere",
  description: "Praktisk guide til bogføring for freelancere: faktura, bilag, moms, bankafstemning og hvad Rentemester faktisk kan hjælpe med.",
  eyebrow: "Freelancere",
  h1: "Bogføring for freelancere uden sort boks",
  lead: "Freelancere har brug for enkel bogføring, men ikke upræcise genveje. Rentemester er et open source regnskabsprojekt under udvikling til lokale data, fakturaer, bilag, moms og audit trail for små danske virksomheder.",
  datePublished: "2026-05-19",
  dateModified: "2026-05-19",
  pageType: "Article" as const,
};

const faq = [
  {
    q: "Kan freelancere bruge Rentemester i dag?",
    a: "Tekniske brugere kan køre projektet lokalt og arbejde med faktura, bilag, momsrapport, bankimport og audit-flow. Det er stadig et open source projekt under udvikling, ikke et færdigt hosted regnskabsprogram.",
  },
  {
    q: "Er Rentemester nok til freelance-bogføring?",
    a: "Det afhænger af virksomheden. Rentemester dækker almindelige småvirksomhedsflows i kodebasen, men du skal stadig kontrollere krav, fradrag og moms med en bogholder eller revisor, hvis du er i tvivl.",
  },
  {
    q: "Er Rentemester et registreret bogføringssystem?",
    a: "Nej. Rentemester må ikke beskrives som et registreret digitalt standardbogføringssystem. Hvis du er omfattet af krav om digital bogføring, skal du kontrollere Erhvervsstyrelsens krav.",
  },
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faq.map((item) => ({
      "@type": "Question",
      name: item.q,
      acceptedAnswer: { "@type": "Answer", text: item.a },
    })),
  },
];
---

<BaseLayout
  title={page.title}
  description={page.description}
  pathname={page.pathname}
  pageType={page.pageType}
  datePublished={page.datePublished}
  dateModified={page.dateModified}
  reviewedBy={SITE.author}
  jsonLd={jsonLd}
>
  <PageHero eyebrow={page.eyebrow} title={page.h1} lead={page.lead} />

  <article class="max-w-3xl mx-auto px-margin-mobile md:px-margin-desktop py-12 md:py-16 prose-da">
    <p>
      Freelance-bogføring handler ofte om få, gentagne flows: send en faktura, gem bilaget, match bankbetalingen, bogfør moms korrekt og bevar dokumentation. Rentemester er bygget til netop den type rutinearbejde, men med en vigtig begrænsning: projektet er kildekode under udvikling, ikke en færdig cloud-service.
    </p>

    <SeoEvidence
      updated={page.dateModified}
      reviewed={SITE.author}
      status="QA-gennemgået mod nuværende kodebase, testede flows og Erhvervsstyrelsens offentlige vejledning om digital bogføring."
      sources={[
        { href: `${SITE.github}/blob/main/package.json`, label: "Rentemester test- og smoke-gates", external: true },
        { href: `${SITE.github}/tree/main/rules/dk`, label: "Danske regler som kode", external: true },
        { href: "https://erhvervsstyrelsen.dk/tidsplan-for-virksomheders-digitale-bogfoering", label: "Erhvervsstyrelsen: tidsplan for digital bogføring", external: true },
      ]}
      related={[
        { href: "/regnskabsprogram", label: "Regnskabsprogram" },
        { href: "/bogfoering-for-enkeltmandsvirksomhed", label: "Enkeltmandsvirksomhed" },
        { href: "/viden/saadan-bogfoerer-du/udlaeg", label: "Bogfør udlæg" },
      ]}
    />

    <h2>Det vigtigste for freelancere</h2>
    <p>
      Som freelancer skal du kunne se forskel på omsætning, udlæg, egne omkostninger, moms og privatøkonomi. Det lyder enkelt, men fejl opstår ofte når bilag mangler, banklinjer ikke afstemmes, eller momsbehandling bliver gætværk.
    </p>
    <ul>
      <li>Udsted fakturaer med tydelige varer, ydelser, moms og betalingsstatus.</li>
      <li>Gem bilag med dato, beløb, leverandør, formål og hash, så dokumentationen kan efterprøves.</li>
      <li>Afstem banklinjer mod fakturaer og køb, så åbne poster ikke driver.</li>
      <li>Brug modposteringer ved rettelser i stedet for at overskrive historik.</li>
      <li>Hold styr på momsperioder, repræsentation, EU reverse charge og private andele.</li>
    </ul>

    <h2>Sådan håndterer Rentemester det</h2>
    <p>
      Rentemester har lokal SQLite-ledger, append-only posteringer, bilagsmetadata, fakturaflow, bank-CSV import, momsrapport, audit-verifikation og eksport i den nuværende kodebase. AI-agenten kan hjælpe med rutinearbejde, men regler og strukturerede tools skal holde bogføringen deterministisk.
    </p>
    <p>
      Det betyder, at systemet passer bedst til tekniske freelancere, konsulenter og små virksomheder, der vil eje data lokalt og kunne inspicere hvad systemet gør. Det er ikke designet som lønmodul, POS-system, lagerstyring eller fuld enterprise accounting.
    </p>

    <h2>Begrænsninger og ansvar</h2>
    <p>
      Rentemester er ikke et registreret digitalt standardbogføringssystem og markedsføres ikke som et færdigt SaaS-produkt. Hvis din virksomhed er omfattet af krav om digital bogføring, skal du kontrollere kravene hos Erhvervsstyrelsen og vælge en løsning, der passer til din situation.
    </p>

    <h2>Næste skridt</h2>
    <ul>
      <li><a href="/docs/installation">Installer Rentemester lokalt</a></li>
      <li><a href="/vaerktoej/momsberegner">Beregn moms på et beløb</a></li>
      <li><a href="/viden/frister/moms">Se momsfrister</a></li>
    </ul>

    <h2>Ofte stillede spørgsmål</h2>
    {faq.map((item) => (
      <>
        <h3>{item.q}</h3>
        <p>{item.a}</p>
      </>
    ))}
  </article>
</BaseLayout>
