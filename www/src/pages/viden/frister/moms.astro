---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHero from "../../../components/PageHero.astro";
import SeoEvidence from "../../../components/SeoEvidence.astro";

const faq = [
  {
    q: "Hvornår skal moms indberettes?",
    a: "Det afhænger af virksomhedens momsperiode. Små virksomheder indberetter typisk halvårligt, mellemstore kvartalsvist og større virksomheder månedligt. Tjek altid den konkrete frist i TastSelv Erhverv.",
  },
  {
    q: "Hvad sker der hvis momsfristen overskrides?",
    a: "Hvis du indberetter eller betaler for sent, kan der komme afgifter, renter og rykkere. Det vigtigste er at få indberettet hurtigst muligt og afstemme bogføringen før næste periode.",
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faq.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: { "@type": "Answer", text: item.a },
  })),
};

const skatFristerUrl = "https://skat.dk/erhverv/moms/frister-indberet-og-betal-moms";
---

<BaseLayout
  title="Momsfrister for danske virksomheder"
  description="Overblik over momsfrister for danske virksomheder: månedlig, kvartalsvis og halvårlig moms, hvad du skal afstemme, og hvordan Rentemester arbejder med perioder."
  pathname="/viden/frister/moms"
  pageType="Article"
  datePublished="2026-05-19"
  dateModified="2026-05-19"
  jsonLd={jsonLd}
>
  <PageHero
    eyebrow="Momsfrister"
    title="Hvornår skal moms indberettes?"
    lead="Momsfristen afhænger af din virksomheds momsperiode. Rentemester kan lave momsrapport for en valgt periode, men du skal altid kontrollere den konkrete frist i TastSelv Erhverv."
  />

  <article class="max-w-3xl mx-auto px-margin-mobile md:px-margin-desktop py-12 md:py-16 prose-da">
    <p>
      Kort version: danske virksomheder indberetter typisk moms månedligt, kvartalsvist eller halvårligt. Hvilken rytme du har, afhænger blandt andet af virksomhedens momspligtige omsætning, om virksomheden er nystartet, og Skattestyrelsens registrering. Den konkrete frist står i TastSelv Erhverv.
    </p>
    <p>
      Kilde: Skattestyrelsens aktuelle oversigt over <a href={skatFristerUrl} rel="noopener" target="_blank">frister for indberetning og betaling af moms</a>. Brug den som facit, hvis datoer eller grænser ændrer sig.
    </p>

    <SeoEvidence
      sources={[
        { href: skatFristerUrl, label: "Skattestyrelsen: frister for moms", external: true },
        { href: "https://www.retsinformation.dk/eli/lta/2024/209", label: "Momsloven", external: true },
      ]}
      related={[
        { href: "/viden/moms/satser", label: "Momssatser" },
        { href: "/vaerktoej/momsberegner", label: "Momsberegner" },
        { href: "/regnskabsprogram", label: "Regnskabsprogram" },
      ]}
    />

    <h2>Typiske momsperioder</h2>
    <ul>
      <li><strong>Månedlig moms:</strong> typisk når den momspligtige omsætning er over 50 mio. kr. årligt, eller hvis virksomheden selv har søgt om månedsvis afregning.</li>
      <li><strong>Kvartalsmoms:</strong> typisk for nystartede virksomheder, virksomheder der selv har søgt om kvartalsvis afregning, eller virksomheder med momspligtig omsætning mellem 5 og 50 mio. kr. årligt.</li>
      <li><strong>Halvårsmoms:</strong> typisk når den momspligtige omsætning er under 5 mio. kr. årligt, og virksomheden har indberettet og betalt til tiden.</li>
    </ul>

    <h2>Hvad bør være klar før fristen?</h2>
    <ul>
      <li>alle salgsfakturaer for perioden</li>
      <li>alle købsbilag og kvitteringer</li>
      <li>bankafstemning for perioden</li>
      <li>korrekt håndtering af EU-køb, repræsentation og kreditnotaer</li>
      <li>momsrapport med udgående moms, indgående moms og nettobeløb</li>
    </ul>

    <h2>Sådan undgår du frist-stress</h2>
    <p>
      Den praktiske fejl er næsten aldrig selve indberetningen. Det er bilagene, afstemningen og usikre posteringer der mangler. Derfor bør bogføringen være løbende, ikke en øvelse aftenen før deadline.
    </p>

    <h2>Sådan håndterer Rentemester det</h2>
    <p>
      Rentemester kan generere en momsrapport for en valgt periode med `vat report`. Den samler udgående moms, indgående moms, reverse charge og særlige momsflows som repræsentation ud fra posteringerne i den lokale ledger. Roadmap'et er at koble det tydeligere til fristkalender, bilagsmail og exceptions, så mangler kan opdages før fristen.
    </p>
    <p>
      Brug også <a href="/vaerktoej/momsberegner">momsberegneren</a> og læs <a href="/viden/moms/satser">momssatser i Danmark</a>.
    </p>

    <h2>Ofte stillede spørgsmål</h2>
    {faq.map((item) => (
      <>
        <h3>{item.q}</h3>
        <p>{item.a}</p>
      </>
    ))}
  </article>
</BaseLayout>
