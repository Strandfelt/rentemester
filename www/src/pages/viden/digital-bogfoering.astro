---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import SeoEvidence from "../../components/SeoEvidence.astro";
import { SITE } from "../../consts";

const page = {
  pathname: "/viden/digital-bogfoering",
  title: "Digital bogføring i Danmark",
  description: "Kort guide til digital bogføring i Danmark: hvem bliver omfattet, hvad et digitalt bogføringssystem skal kunne, og Rentemesters status.",
  datePublished: "2026-05-19",
  dateModified: "2026-05-19",
};

const faq = [
  {
    q: "Er Rentemester et registreret digitalt bogføringssystem?",
    a: "Nej. Rentemester er open source-kode under udvikling og må ikke beskrives som et registreret standardbogføringssystem.",
  },
  {
    q: "Hvornår gælder krav om digital bogføring?",
    a: "Kravene indføres løbende efter virksomhedsform, regnskabsår og omsætning. Tjek Erhvervsstyrelsens aktuelle tidsplan for den konkrete vurdering.",
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faq.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: { "@type": "Answer", text: item.a },
  })),
};
---

<BaseLayout
  title={page.title}
  description={page.description}
  pathname={page.pathname}
  pageType="Article"
  datePublished={page.datePublished}
  dateModified={page.dateModified}
  reviewedBy={SITE.author}
  jsonLd={jsonLd}
>
  <PageHero
    eyebrow="Digital bogføring"
    title="Digital bogføring uden overclaiming"
    lead="Digital bogføring er ikke bare at bruge en computer. Reglerne handler om registrering, opbevaring, sikkerhedskopi, bilag og systemkrav. Rentemester arbejder i den retning, men er ikke et registreret standardbogføringssystem."
  />

  <article class="max-w-3xl mx-auto px-margin-mobile md:px-margin-desktop py-12 md:py-16 prose-da">
    <p>
      Kort version: digital bogføring bliver et krav for flere danske virksomheder, men tidspunktet afhænger af virksomhedsform, regnskabsår og omsætning. Hvis din virksomhed er omfattet, skal du sikre at systemet og arbejdsgangen lever op til kravene.
    </p>

    <SeoEvidence
      sources={[
        { href: "https://erhvervsstyrelsen.dk/tidsplan-for-virksomheders-digitale-bogfoering", label: "Erhvervsstyrelsen: tidsplan for digital bogføring", external: true },
        { href: "https://erhvervsstyrelsen.dk/hvem-skal-bogfoere-og-hvem-skal-bogfoere-digitalt", label: "Erhvervsstyrelsen: hvem skal bogføre digitalt", external: true },
        { href: "https://erhvervsstyrelsen.dk/ikke-registrerede-digitale-bogfoeringssystemer", label: "Erhvervsstyrelsen: ikke-registrerede systemer", external: true },
      ]}
      related={[
        { href: "/open-source-regnskabsprogram", label: "Open source-regnskabsprogram" },
        { href: "/bogfoering-for-enkeltmandsvirksomhed", label: "Enkeltmandsvirksomhed" },
        { href: "/bogfoering-for-aps", label: "ApS" },
      ]}
    />

    <h2>Hvad skal du afklare først?</h2>
    <ul>
      <li>Om virksomheden er årsregnskabspligtig eller personligt ejet.</li>
      <li>Hvornår regnskabsåret starter.</li>
      <li>Om virksomheden bruger registreret eller ikke-registreret system.</li>
      <li>Om omsætningstærskler for personligt ejede virksomheder er relevante.</li>
      <li>Hvordan bilag, transaktioner, backup og afstemning dokumenteres.</li>
    </ul>

    <h2>Sådan håndterer Rentemester det</h2>
    <p>
      Rentemester har lokale data, SQLite-ledger, bilag med hash, append-only posteringer, backup/restore, audit-verifikation og eksport/handoff i kodebasen. Det er relevante byggesten for digital bogføring, men siden lover ikke formel compliance eller registrering.
    </p>

    <h2>Hvad må vi ikke sige?</h2>
    <p>
      Vi må ikke kalde Rentemester et færdigt registreret bogføringssystem, og vi må ikke antyde at alle virksomheder kan bruge projektet som lovpligtigt system uden egen vurdering. Den ærlige formulering er: et open source-projekt under udvikling med flere af de tekniske kontrolspor, digital bogføring kræver.
    </p>

    <h2>Ofte stillede spørgsmål</h2>
    {faq.map((item) => (
      <>
        <h3>{item.q}</h3>
        <p>{item.a}</p>
      </>
    ))}
  </article>
</BaseLayout>
