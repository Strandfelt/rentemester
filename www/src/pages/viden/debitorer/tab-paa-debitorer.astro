---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHero from "../../../components/PageHero.astro";
import SeoEvidence from "../../../components/SeoEvidence.astro";
import { SITE } from "../../../consts";
---

<BaseLayout
  title="Bogfør tab på debitorer"
  description="Sådan bogfører du tab på debitorer: åben faktura, vurdering af tab, momsregulering, dokumentation og Rentemesters write-off flow."
  pathname="/viden/debitorer/tab-paa-debitorer"
  pageType="Article"
  datePublished="2026-05-19"
  dateModified="2026-05-19"
  reviewedBy={SITE.author}
>
  <PageHero
    eyebrow="Debitorer"
    title="Tab på debitorer skal ikke skjules"
    lead="Når en kunde ikke betaler, skal tabet håndteres som en dokumenteret regnskabshændelse. Det kræver åben saldo, vurdering, eventuel momsregulering og sporbar bogføring."
  />

  <article class="max-w-3xl mx-auto px-margin-mobile md:px-margin-desktop py-12 md:py-16 prose-da">
    <p>
      Tab på debitorer opstår, når en faktura ikke kan inddrives. Det er ikke det samme som en kreditnota. Kreditnota retter et salg; tab på debitorer håndterer et krav, der stadig var reelt, men som ikke bliver betalt.
    </p>

    <SeoEvidence
      sources={[
        { href: `${SITE.github}/tree/main/tests/unit`, label: "Rentemester bad-debt tests", external: true },
        { href: `${SITE.github}/tree/main/rules/dk`, label: "Rentemester moms- og debitorregler", external: true },
      ]}
      related={[
        { href: "/viden/debitorer/rykkergebyr-morarente", label: "Rykkergebyr og morarente" },
        { href: "/viden/saadan-bogfoerer-du/kreditnota", label: "Kreditnota" },
        { href: "/viden/saadan-bogfoerer-du/faktura", label: "Bogfør faktura" },
      ]}
    />

    <h2>Før du bogfører tabet</h2>
    <ul>
      <li>Kontroller den oprindelige faktura og åben saldo.</li>
      <li>Dokumentér hvorfor kravet vurderes tabt.</li>
      <li>Adskil tabet fra kreditnota og almindelig betaling.</li>
      <li>Vurder momsbehandlingen fagligt ved tvivl.</li>
      <li>Bevar sporbarhed til faktura og eventuelle rykkerkrav.</li>
    </ul>

    <h2>Sådan håndterer Rentemester det</h2>
    <p>
      Rentemester har et testet write-off flow for tab på debitorer, hvor åben saldo reduceres, tabet bogføres og momsrelief håndteres deterministisk for standard-rated fakturaer. Siden lover ikke automatisk juridisk vurdering af om et krav faktisk er tabt; den beskriver den bogføringstekniske behandling, koden understøtter.
    </p>
  </article>
</BaseLayout>
