---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHero from "../../../components/PageHero.astro";
import SeoEvidence from "../../../components/SeoEvidence.astro";
import { SITE } from "../../../consts";
---

<BaseLayout
  title="Fakturastatus og åbne poster"
  description="Fakturastatus forklaret: ubetalt, betalt, forfalden, krediteret, refunderet, tabt og hvordan Rentemester beregner åben saldo."
  pathname="/viden/debitorer/faktura-status"
  pageType="Article"
  datePublished="2026-05-19"
  dateModified="2026-05-19"
  reviewedBy={SITE.author}
>
  <PageHero eyebrow="Debitorer" title="Fakturastatus skal beregnes, ikke gættes" lead="En faktura kan være åben, betalt, forfalden, delvist krediteret, refunderet eller tabt. Status skal komme fra bogførte hændelser, ikke manuelle labels." />

  <article class="max-w-3xl mx-auto px-margin-mobile md:px-margin-desktop py-12 md:py-16 prose-da">
    <p>
      Fakturastatus er vigtig for likviditet og opfølgning. Hvis status bare er et felt, nogen kan ændre, mister du forbindelsen til betalinger, kreditnotaer, rykkerkrav og tab. Derfor bør status beregnes fra hændelser.
    </p>

    <SeoEvidence
      sources={[
        { href: `${SITE.github}/tree/main/tests/unit`, label: "Rentemester invoice status tests", external: true },
        { href: `${SITE.github}/tree/main/src`, label: "Invoice lifecycle i kildekoden", external: true },
      ]}
      related={[
        { href: "/viden/saadan-bogfoerer-du/faktura", label: "Bogfør faktura" },
        { href: "/viden/debitorer/refundering", label: "Refundering" },
        { href: "/viden/debitorer/rykkergebyr-morarente", label: "Rykker og morarente" },
      ]}
    />

    <h2>Status bør afhænge af</h2>
    <ul>
      <li>oprindeligt fakturabeløb</li>
      <li>betalinger</li>
      <li>kreditnotaer</li>
      <li>refunderinger</li>
      <li>rykkerkrav, renter og kompensation</li>
      <li>bad-debt write-off</li>
    </ul>

    <h2>Sådan håndterer Rentemester det</h2>
    <p>
      Rentemester har testede statusflows, der beregner åben saldo ud fra faktura, betalinger, kreditnotaer, refunds, claims og write-offs. Det gør status til et resultat af ledgeren, ikke et pyntet dashboardfelt.
    </p>
    <p>
      Det er især vigtigt ved delbetalinger, kreditnotaer og <a href="/viden/debitorer/refundering">refunderinger</a>, hvor den åbne saldo ellers let kan blive forkert. En statusvisning skal derfor kunne forklare både hovedstol og særskilte krav som rykkergebyr eller renter.
    </p>
  </article>
</BaseLayout>
