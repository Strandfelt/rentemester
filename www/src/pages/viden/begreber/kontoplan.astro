---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHero from "../../../components/PageHero.astro";
import SeoEvidence from "../../../components/SeoEvidence.astro";
import { SITE } from "../../../consts";
---

<BaseLayout
  title="Kontoplan for små virksomheder"
  description="Hvad er en kontoplan, og hvordan bruger små virksomheder den til salg, moms, bank, omkostninger og dokumenteret bogføring?"
  pathname="/viden/begreber/kontoplan"
  pageType="Article"
  datePublished="2026-05-19"
  dateModified="2026-05-19"
  reviewedBy={SITE.author}
>
  <PageHero
    eyebrow="Begreber"
    title="Kontoplanen er regnskabets struktur"
    lead="En kontoplan bestemmer hvor salg, moms, bank, udgifter og egenkapital lander. Den gør regnskabet læsbart og gør automatisering mindre risikabel."
  />

  <article class="max-w-3xl mx-auto px-margin-mobile md:px-margin-desktop py-12 md:py-16 prose-da">
    <p>
      En kontoplan er listen over konti, virksomheden bogfører på. For små virksomheder handler den ikke om flest mulige konti, men om nok struktur til at moms, bank, omsætning og omkostninger kan afstemmes.
    </p>

    <SeoEvidence
      sources={[
        { href: `${SITE.github}/tree/main/rules/dk`, label: "Rentemester danske regler", external: true },
        { href: `${SITE.github}/tree/main/src`, label: "Rentemester kildekode", external: true },
      ]}
      related={[
        { href: "/viden/begreber/debet-kredit", label: "Debet og kredit" },
        { href: "/viden/moms/satser", label: "Momssatser" },
        { href: "/funktioner", label: "Funktioner" },
      ]}
    />

    <h2>Typiske kontoområder</h2>
    <ul>
      <li>bank og likvider</li>
      <li>debitorer og kreditorer</li>
      <li>salg og anden indtægt</li>
      <li>køb og driftsomkostninger</li>
      <li>moms og afgifter</li>
      <li>egenkapital, mellemregning og resultat</li>
    </ul>

    <h2>Sådan håndterer Rentemester det</h2>
    <p>
      Rentemester bruger en kontoplan som del af den lokale ledger og regelmotor. Det gør det muligt at validere posteringer og holde moms- og auditflow tæt på kildekoden i stedet for fri tekst.
    </p>
    <p>
      En god kontoplan bør være stabil nok til rapportering, men enkel nok til at små virksomheder faktisk bruger den rigtigt. Når konti bliver for detaljerede, ender brugeren ofte med tilfældige valg; når de er for grove, bliver moms, bank og omkostninger svære at forklare senere.
    </p>
  </article>
</BaseLayout>
