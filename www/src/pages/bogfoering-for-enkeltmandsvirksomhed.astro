---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SeoEvidence from "../components/SeoEvidence.astro";
import { SITE } from "../consts";

const page = {
  pathname: "/bogfoering-for-enkeltmandsvirksomhed",
  title: "Bogføring for enkeltmandsvirksomhed",
  description: "Bogføring for enkeltmandsvirksomhed: bilag, moms, bank, privatøkonomi og hvordan Rentemester understøtter små danske flows.",
  eyebrow: "Enkeltmandsvirksomhed",
  h1: "Bogføring for enkeltmandsvirksomhed med lokal kontrol",
  lead: "En enkeltmandsvirksomhed har ofte enkel drift, men bogføringen skal stadig være dokumenteret, afstemt og adskilt fra privatøkonomi. Rentemester bygger et åbent, lokalt workflow til den type små danske virksomheder.",
  datePublished: "2026-05-19",
  dateModified: "2026-05-19",
  pageType: "Article" as const,
};

const faq = [
  {
    q: "Hvad skal en enkeltmandsvirksomhed typisk holde styr på?",
    a: "Bilag, fakturaer, bankbevægelser, moms, privat andel, udlæg og dokumentation. Kravene afhænger af den konkrete virksomhed og reglerne for digital bogføring.",
  },
  {
    q: "Kan Rentemester adskille privat og virksomhed?",
    a: "Rentemester kan bogføre og dokumentere transaktioner lokalt, men korrekt håndtering af privat andel og ejerforhold afhænger af virksomhedens konkrete forhold og bør kontrolleres fagligt.",
  },
  {
    q: "Hvornår gælder krav om digital bogføring?",
    a: "Erhvervsstyrelsen indfører kravene løbende. Personligt ejede virksomheder kan blive omfattet afhængigt af omsætning og regnskabsår, så tjek den aktuelle tidsplan hos Erhvervsstyrelsen.",
  },
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faq.map((item) => ({
      "@type": "Question",
      name: item.q,
      acceptedAnswer: { "@type": "Answer", text: item.a },
    })),
  },
];
---

<BaseLayout
  title={page.title}
  description={page.description}
  pathname={page.pathname}
  pageType={page.pageType}
  datePublished={page.datePublished}
  dateModified={page.dateModified}
  reviewedBy={SITE.author}
  jsonLd={jsonLd}
>
  <PageHero eyebrow={page.eyebrow} title={page.h1} lead={page.lead} />

  <article class="max-w-3xl mx-auto px-margin-mobile md:px-margin-desktop py-12 md:py-16 prose-da">
    <p>
      Bogføring i en enkeltmandsvirksomhed bliver ofte svær, fordi virksomheden og ejeren ligger tæt på hinanden i hverdagen. Systemet skal hjælpe med bilag, bank og moms, men det må ikke skjule hvad der er virksomhedens aktivitet, og hvad der er privat.
    </p>

    <SeoEvidence
      updated={page.dateModified}
      reviewed={SITE.author}
      status="QA-gennemgået mod nuværende kodebase, testede flows og officiel vejledning om digital bogføring."
      sources={[
        { href: `${SITE.github}/tree/main/src`, label: "Rentemester kildekode", external: true },
        { href: `${SITE.github}/tree/main/rules/dk`, label: "Danske regler som kode", external: true },
        { href: "https://erhvervsstyrelsen.dk/tidsplan-for-virksomheders-digitale-bogfoering", label: "Erhvervsstyrelsen: tidsplan for digital bogføring", external: true },
      ]}
      related={[
        { href: "/bogfoering-for-freelancere", label: "Freelancere" },
        { href: "/regnskabsprogram", label: "Regnskabsprogram" },
        { href: "/viden/moms/satser", label: "Momssatser" },
      ]}
    />

    <h2>De typiske bogføringsopgaver</h2>
    <p>
      For mange enkeltmandsvirksomheder er kernen et overskueligt sæt gentagelser. Risikoen ligger ikke i kompleks koncernregnskab, men i manglende bilag, fejl i moms, uafstemte banklinjer og uklare private hævninger eller andele.
    </p>
    <ul>
      <li>Fakturaer skal udstedes, bogføres og markeres betalt.</li>
      <li>Køb skal have bilag, leverandør, dato, beløb og formål.</li>
      <li>Banken skal afstemmes, så betalinger ikke bare står som løse linjer.</li>
      <li>Moms skal håndteres efter sats, periode og eventuelle særlige regler.</li>
      <li>Rettelser skal kunne forklares senere, ikke bare redigere historikken væk.</li>
    </ul>

    <h2>Sådan håndterer Rentemester det</h2>
    <p>
      Rentemester arbejder med lokal virksomhedsmappe, SQLite-ledger, bilag, bankimport, fakturaer, momsrapport, audit trail og eksport. Det passer til små virksomheder, hvor gennemsigtighed og ejerskab over data er vigtigere end en poleret SaaS-overflade.
    </p>
    <p>
      Projektet bruger deterministiske regler og tests, så AI-assistance ikke bliver det samme som fri tekstgætteri. Agenten kan forberede og strukturere arbejde, men bogføringen skal stadig passere systemets regler.
    </p>

    <h2>Begrænsninger og ansvar</h2>
    <p>
      Rentemester er ikke juridisk rådgivning, revisorerklæring eller et registreret standardbogføringssystem. Enkeltmandsvirksomheder kan blive omfattet af krav om digital bogføring, og kravene afhænger af omsætning, virksomhedsform og tidspunkt. Brug officielle kilder og faglig rådgivning til den endelige vurdering.
    </p>

    <h2>Næste skridt</h2>
    <ul>
      <li><a href="/funktioner">Se hvilke funktioner kodebasen understøtter</a></li>
      <li><a href="/bogfoeringsprogram">Læs om bogføringsprogrammet</a></li>
      <li><a href="/viden/saadan-bogfoerer-du/udlaeg">Lær at bogføre udlæg</a></li>
    </ul>

    <h2>Ofte stillede spørgsmål</h2>
    {faq.map((item) => (
      <>
        <h3>{item.q}</h3>
        <p>{item.a}</p>
      </>
    ))}
  </article>
</BaseLayout>
