---
import { SITE } from "../consts";
import { FOOTER_KNOWLEDGE_LINKS, FOOTER_LEGAL_LINKS, FOOTER_PROJECT_LINKS } from "../site-map";
const year = new Date().getFullYear();
---

<footer class="bg-surface-container-lowest border-t border-outline-variant/30 mt-24">
  <div class="max-w-container mx-auto px-margin-mobile md:px-margin-desktop py-16 grid gap-12 md:grid-cols-4">
    <div class="md:col-span-2">
      <div class="font-serif text-2xl text-primary mb-3">{SITE.name}</div>
      <p class="text-on-surface-variant text-[15px] max-w-md leading-relaxed">
        Open source bogføringssystem til danske mikrovirksomheder, freelancere og små ApS'er. Drevet af et community — ikke en virksomhed.
      </p>
      <a
        href={SITE.github}
        rel="noopener me"
        target="_blank"
        class="inline-flex items-center gap-2 mt-6 font-mono text-[12px] uppercase tracking-[0.1em] text-primary hover:text-cyber-blue transition-colors"
      >
        <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path d="M8 0C3.58 0 0 3.58 0 8a8 8 0 005.47 7.59c.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"/>
        </svg>
        {SITE.githubRaw}
      </a>
    </div>

    <div>
      <div class="font-mono text-[11px] uppercase tracking-[0.2em] text-outline mb-4">Projekt</div>
      <ul class="space-y-2 text-[15px]">
        {FOOTER_PROJECT_LINKS.map((link) => (
          <li><a href={link.href} class="text-on-surface-variant hover:text-primary">{link.label}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <div class="font-mono text-[11px] uppercase tracking-[0.2em] text-outline mb-4">Viden</div>
      <ul class="space-y-2 text-[15px]">
        {FOOTER_KNOWLEDGE_LINKS.map((link) => (
          <li><a href={link.href} class="text-on-surface-variant hover:text-primary">{link.label}</a></li>
        ))}
        <li><a href={`${SITE.github}/blob/main/CONTRIBUTING.md`} rel="noopener" target="_blank" class="text-on-surface-variant hover:text-primary">Bidragsguide ↗</a></li>
      </ul>
    </div>
  </div>

  <div class="border-t border-outline-variant/20">
    <div class="max-w-container mx-auto px-margin-mobile md:px-margin-desktop py-6 flex flex-col md:flex-row justify-between gap-4 text-[12px] font-mono uppercase tracking-[0.1em] text-outline">
      <div>© {year} {SITE.author} · MIT-licens · ingen tracking, ingen cookies</div>
      <div class="flex flex-wrap gap-6">
        {FOOTER_LEGAL_LINKS.map((link) => (
          <a href={link.href} class="hover:text-primary">{link.label}</a>
        ))}
      </div>
    </div>
  </div>
</footer>
