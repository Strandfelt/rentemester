---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE } from "../consts";
import { labelForPath } from "../site-map";

type LinkItem = {
  href: string;
  label: string;
};

export interface Props {
  title?: string;
  description?: string;
  pathname?: string;
  ogImage?: string;
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  datePublished?: string;
  dateModified?: string;
  reviewedBy?: string;
  pageType?: "WebPage" | "AboutPage" | "ContactPage" | "Article" | "FAQPage" | "SoftwareApplication";
  breadcrumbs?: LinkItem[];
  /** Override the rendered page title fully (used on the homepage). */
  titleOverride?: string;
}

const {
  title,
  description = SITE.description,
  pathname: rawPathname = Astro.url.pathname,
  ogImage = "/og-default.png",
  noindex = false,
  jsonLd,
  datePublished,
  dateModified,
  reviewedBy,
  pageType = "WebPage",
  breadcrumbs,
  titleOverride,
} = Astro.props;

const pathname = rawPathname === "/index.html"
  ? "/"
  : rawPathname.replace(/\/index\.html$/, "").replace(/\.html$/, "");

const fullTitle = titleOverride
  ? titleOverride
  : title
    ? `${title} · ${SITE.name}`
    : `${SITE.name} — ${SITE.tagline}`;

const canonical = new URL(pathname, SITE.url).toString();
const ogImageUrl = new URL(ogImage, SITE.url).toString();
const normalizedPath = pathname === "/" ? "/" : pathname.replace(/\/$/, "");

const generatedBreadcrumbs: LinkItem[] = (() => {
  if (breadcrumbs) return breadcrumbs;
  if (normalizedPath === "/") return [];
  return [
    { href: "/", label: "Forside" },
    {
      href: normalizedPath,
      label: labelForPath(normalizedPath),
    },
  ];
})();

const pageJsonLd = {
  "@context": "https://schema.org",
  "@type": pageType,
  "@id": `${canonical}#webpage`,
  url: canonical,
  name: fullTitle,
  headline: title ?? SITE.name,
  description,
  inLanguage: SITE.lang === "da" ? "da-DK" : SITE.lang,
  isPartOf: { "@id": `${SITE.url}/#website` },
  publisher: {
    "@type": "Organization",
    "@id": `${SITE.url}/#organization`,
    name: SITE.name,
    logo: { "@type": "ImageObject", url: new URL("/favicon.svg", SITE.url).toString() },
  },
  image: ogImageUrl,
  author: { "@type": "Person", name: SITE.author },
  mainEntityOfPage: canonical,
  ...(datePublished ? { datePublished } : {}),
  ...(dateModified ? { dateModified } : {}),
  ...(reviewedBy ? { reviewedBy: { "@type": "Person", name: reviewedBy } } : {}),
};

const orgJsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": `${SITE.url}/#organization`,
  name: SITE.name,
  url: SITE.url,
  logo: new URL("/favicon.svg", SITE.url).toString(),
  founder: { "@type": "Person", name: SITE.author },
  sameAs: [SITE.github],
};

const websiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${SITE.url}/#website`,
  name: SITE.name,
  url: SITE.url,
  inLanguage: "da-DK",
  description: SITE.description,
  publisher: { "@id": `${SITE.url}/#organization` },
};

const softwareJsonLd = {
  "@context": "https://schema.org",
  "@type": ["SoftwareApplication", "SoftwareSourceCode"],
  name: SITE.name,
  applicationCategory: "BusinessApplication",
  operatingSystem: "Linux, macOS, Windows",
  offers: { "@type": "Offer", price: "0", priceCurrency: "DKK" },
  description: SITE.description,
  codeRepository: SITE.github,
  programmingLanguage: "TypeScript",
  author: { "@type": "Person", name: SITE.author },
  maintainer: { "@type": "Person", name: SITE.author },
  license: "https://opensource.org/licenses/MIT",
  inLanguage: "da-DK",
  url: SITE.url,
  isAccessibleForFree: true,
  isPartOf: { "@id": `${SITE.url}/#website` },
};

const breadcrumbJsonLd = generatedBreadcrumbs.length > 1
  ? {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: generatedBreadcrumbs.map((item, index) => ({
        "@type": "ListItem",
        position: index + 1,
        name: item.label,
        item: new URL(item.href, SITE.url).toString(),
      })),
    }
  : null;

const allJsonLd = [
  orgJsonLd,
  websiteJsonLd,
  softwareJsonLd,
  pageJsonLd,
  ...(breadcrumbJsonLd ? [breadcrumbJsonLd] : []),
  ...(jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : []),
];
---

<!doctype html>
<html lang={SITE.lang} class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    {noindex && <meta name="robots" content="noindex,nofollow" />}
    {!noindex && <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />}

    <meta name="author" content={SITE.author} />
    <meta name="theme-color" content="#05070A" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:locale" content={SITE.locale} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:alt" content={`${SITE.name} — ${SITE.tagline}`} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Discovery -->
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="author" href="/om" />
    <link rel="privacy-policy" href="/privatlivspolitik" />

    <!-- Structured data -->
    {allJsonLd.map((data) => (
      <script type="application/ld+json" set:html={JSON.stringify(data)} />
    ))}

    <!-- AEO/LLM hint -->
    <link rel="alternate" type="text/markdown" href="/llms.txt" />
  </head>
  <body class="min-h-screen bg-ink-black text-on-surface antialiased">
    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 focus:bg-brass-gold focus:text-ink-black focus:px-3 focus:py-2 focus:font-mono focus:text-xs">Spring til indhold</a>
    <Header />
    <main id="main" class="pt-16">
      {generatedBreadcrumbs.length > 1 && (
        <nav aria-label="Brødkrumme" class="max-w-container mx-auto px-margin-mobile md:px-margin-desktop pt-5 -mb-3">
          <ol class="flex flex-wrap items-center gap-2 font-mono text-[11px] uppercase tracking-[0.12em] text-outline">
            {generatedBreadcrumbs.map((item, index) => {
              const isLast = index === generatedBreadcrumbs.length - 1;
              return (
                <li class="flex items-center gap-2">
                  {index > 0 && <span aria-hidden="true">/</span>}
                  {isLast ? (
                    <span class="text-on-surface-variant">{item.label}</span>
                  ) : (
                    <a href={item.href} class="hover:text-primary">{item.label}</a>
                  )}
                </li>
              );
            })}
          </ol>
        </nav>
      )}
      {datePublished && normalizedPath !== "/" && !noindex && (
        <div class="byline article-meta max-w-container mx-auto px-margin-mobile md:px-margin-desktop pt-6 -mb-6 font-mono text-[11px] uppercase tracking-[0.12em] text-outline" itemscope itemtype="https://schema.org/Article">
          <span class="author" itemprop="author" itemscope itemtype="https://schema.org/Person">
            By <a href="/om" rel="author" itemprop="url" class="text-on-surface-variant hover:text-primary"><span class="author-name" itemprop="name">{SITE.author}</span></a>
          </span>
          <span aria-hidden="true"> · </span>
          <span>Published <time class="published-date" datetime={datePublished} itemprop="datePublished">{datePublished}</time></span>
          <span aria-hidden="true"> · </span>
          <span>Updated <time class="updated-date" datetime={dateModified ?? datePublished} itemprop="dateModified">{dateModified ?? datePublished}</time></span>
        </div>
      )}
      <slot />
    </main>
    <Footer />
  </body>
</html>
